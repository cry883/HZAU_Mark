generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

model User {
  id             String      @id @default(cuid())
  username       String      @unique
  passwordHash   String
  role           Role        @default(USER)
  inviteCodeId   String?
  inviteCodeUsed InviteCode? @relation("UsedBy", fields: [inviteCodeId], references: [id])
  createdAt      DateTime    @default(now())

  issuedCodes    InviteCode[]    @relation("IssuedBy")
  boards         Board[]
  boardItems     BoardItem[]
  reviews        Review[]
  reviewLikes    ReviewLike[]
  moderationLogs ModerationLog[]
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  isActive  Boolean  @default(true)
  issuerId  String
  issuer    User     @relation("IssuedBy", fields: [issuerId], references: [id])
  usedBy    User[]   @relation("UsedBy")
  createdAt DateTime @default(now())
}

model Board {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      ModerationStatus @default(PENDING)
  isLocked    Boolean          @default(false)
  creatorId   String
  creator     User             @relation(fields: [creatorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  boardItems      BoardBoardItem[]
  moderationLogs  ModerationLog[]

  @@index([status])
}

model BoardItem {
  id          String           @id @default(cuid())
  name        String
  description String
  imageUrl    String
  status      ModerationStatus @default(PENDING)
  isLocked    Boolean          @default(false)
  creatorId   String
  creator     User             @relation(fields: [creatorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  boards          BoardBoardItem[]
  reviews         Review[]
  moderationLogs  ModerationLog[]

  @@index([status])
}

model BoardBoardItem {
  boardId     String
  boardItemId String
  addedAt     DateTime @default(now())

  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardItem   BoardItem @relation(fields: [boardItemId], references: [id], onDelete: Cascade)

  @@id([boardId, boardItemId])
}

model Review {
  id          String   @id @default(cuid())
  rating      Float
  comment     String?
  userId      String
  boardItemId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardItem   BoardItem @relation(fields: [boardItemId], references: [id], onDelete: Cascade)
  likes       ReviewLike[]

  @@unique([userId, boardItemId])
  @@index([boardItemId])
}

model ReviewLike {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model ModerationLog {
  id          String           @id @default(cuid())
  targetType  String
  targetId    String
  status      ModerationStatus
  reason      String?
  adminId     String
  boardId     String?
  boardItemId String?
  createdAt   DateTime         @default(now())

  admin       User       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  board       Board?     @relation(fields: [boardId], references: [id], onDelete: SetNull)
  boardItem   BoardItem? @relation(fields: [boardItemId], references: [id], onDelete: SetNull)
}
